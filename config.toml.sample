[app]
# Interface and port where the app will run its webserver.  The default value
# of localhost will only listen to connections from the current machine. To
# listen on all interfaces use '0.0.0.0'. To listen on the default web address
# port, use port 80 (this will require running with elevated permissions).
address = "localhost:9000"

# Multi-tenancy (fork-only feature, not upstream). When enabled, every
# request must arrive on a subdomain of root_domain (<slug>.root_domain)
# identifying an active tenant, or it's rejected. Leave disabled (default)
# for a normal single-tenant install - nothing else changes.
multi_tenancy_enabled = false
root_domain = ""

# Database.
[db]
host = "localhost"
port = 5432
user = "listmonk"
password = "listmonk"

# Ensure that this database has been created in Postgres.
database = "listmonk"

ssl_mode = "disable"
max_open = 25
max_idle = 25
max_lifetime = "300s"

# Optional space separated Postgres DSN params. eg: "application_name=listmonk gssencmode=disable"
params = ""

# Operator API (fork-only, multi-tenancy companion feature, not upstream).
# A separate, cross-tenant API for provisioning/managing tenants - distinct
# from the tenant-facing app, authenticated by a single static bearer
# token instead of user sessions. Leave token empty (default) to disable
# it entirely; this is an advanced feature most single-tenant installs
# will never need. See docs/design/multi-tenancy.md's "Operator API"
# section before enabling this in production.
[operator]
token = ""

# DB credentials for a *separate* Postgres role with the BYPASSRLS
# attribute, connecting to the same host/port/database as [db] above -
# required because listing/aggregating data across every tenant at once
# is impossible under Row-Level Security using the normal app role (which
# must never have BYPASSRLS). Leave empty to use [db]'s own credentials
# (only appropriate for local development, never production - see the
# design doc for how to create this role).
db_user = ""
db_password = ""

# Set to "dev" to distinguish this instance's tenant subdomains from a
# separate prod deployment sharing the same root_domain - generated/
# resolved tenant URLs become <slug>-dev.root_domain instead of
# <slug>.root_domain. Leave empty (default) for prod - no suffix.
env = ""
