# Copy to .env.local and fill in with real values.
# For local dev against docker-compose.yml's Zitadel: run
# `./scripts/setup-zitadel.sh` and paste its output below.

VITE_OIDC_AUTHORITY=http://localhost:8081
VITE_OIDC_CLIENT_ID=
VITE_OIDC_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173

# Base URL the API client calls -- proxied to the Go backend in dev (see
# vite.config.ts), so this can stay relative.
VITE_API_BASE_URL=/api
