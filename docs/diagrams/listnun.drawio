  <diagram id="page7-tenant-lifecycle" name="7 - Tenant Lifecycle">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1150" pageHeight="520" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="p7_pending" value="pending&#10;(see diagram 4 for the provisioning sub-flow)" style="rounded=1;arcSize=40;whiteSpace=wrap;html=1;fillColor=#eceef1;strokeColor=#565f6b;fontSize=12;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="220" height="70" as="geometry" />
        </mxCell>

        <mxCell id="p7_active" value="active" style="rounded=1;arcSize=40;whiteSpace=wrap;html=1;fillColor=#e6f2ea;strokeColor=#3f8f5f;fontColor=#3f8f5f;fontSize=12;fontFamily=Courier New;" vertex="1" parent="1">
