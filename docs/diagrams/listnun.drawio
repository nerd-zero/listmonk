        </mxCell>

        <mxCell id="p7_failed" value="failed" style="rounded=1;arcSize=40;whiteSpace=wrap;html=1;fillColor=#fbe9e7;strokeColor=#b3453f;fontColor=#b3453f;fontSize=12;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="40" y="200" width="220" height="60" as="geometry" />
        </mxCell>

        <mxCell id="p7_suspended" value="suspended&#10;(billing issue or admin action)" style="rounded=1;arcSize=40;whiteSpace=wrap;html=1;fillColor=#fdf3e7;strokeColor=#b8792e;fontColor=#b8792e;fontSize=12;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="680" y="60" width="240" height="70" as="geometry" />
        </mxCell>

        <mxCell id="p7_deprovisioning" value="deprovisioning&#10;(Postmark server + Cloudflare hostname removed)" style="rounded=1;arcSize=40;whiteSpace=wrap;html=1;fillColor=#f1e9f5;strokeColor=#7a5a8c;fontColor=#7a5a8c;fontSize=12;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="680" y="200" width="240" height="80" as="geometry" />
        </mxCell>

        <mxCell id="p7_deleted" value="deleted" style="rounded=1;arcSize=40;whiteSpace=wrap;html=1;fillColor=#eceef1;strokeColor=#565f6b;fontSize=12;fontFamily=Courier New;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="330" width="180" height="60" as="geometry" />
        </mxCell>

        <mxCell id="p7_e1" value="provisioning succeeds" style="html=1;strokeColor=#3f8f5f;fontColor=#3f8f5f;fontSize=10;rounded=0;" edge="1" parent="1" source="p7_pending" target="p7_active"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p7_e2" value="retries exhausted" style="html=1;strokeColor=#b3453f;fontColor=#b3453f;fontSize=10;dashed=1;rounded=0;" edge="1" parent="1" source="p7_pending" target="p7_failed"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p7_e3" value="retry" style="html=1;strokeColor=#565f6b;fontColor=#565f6b;fontSize=10;dashed=1;rounded=0;" edge="1" parent="1" source="p7_failed" target="p7_pending"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p7_e4" value="suspend" style="html=1;strokeColor=#b8792e;fontColor=#b8792e;fontSize=10;rounded=0;" edge="1" parent="1" source="p7_active" target="p7_suspended"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p7_e5" value="reinstate" style="html=1;strokeColor=#3f8f5f;fontColor=#3f8f5f;fontSize=10;dashed=1;rounded=0;" edge="1" parent="1" source="p7_suspended" target="p7_active"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p7_e6" value="customer deletes" style="html=1;strokeColor=#7a5a8c;fontColor=#7a5a8c;fontSize=10;rounded=0;" edge="1" parent="1" source="p7_active" target="p7_deprovisioning"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p7_e7" value="customer deletes / retention expires" style="html=1;strokeColor=#7a5a8c;fontColor=#7a5a8c;fontSize=10;rounded=0;" edge="1" parent="1" source="p7_suspended" target="p7_deprovisioning"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p7_e8" value="cleanup complete" style="html=1;strokeColor=#565f6b;fontSize=10;rounded=0;" edge="1" parent="1" source="p7_deprovisioning" target="p7_deleted"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
