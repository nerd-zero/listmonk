# Copy to .env and fill in. The Makefile loads this automatically
# (-include .env) and exports everything to `go run`/`swag`/etc.

# Matches docker-compose.yml's listnun-db by default.
DATABASE_URL=postgres://listnun:listnun@localhost:5432/listnun?sslmode=disable

# cmd/api's listen address.
HTTP_ADDR=:8181

# docker-compose.yml's Zitadel, remapped to 8081 (8080 was already taken
# by something else when this was set up -- see docs/plan.md).
ZITADEL_ISSUER=http://localhost:8081
# From `make setup-zitadel`'s output (web/scripts/setup-zitadel.sh).
ZITADEL_CLIENT_ID=

# Optional: only needed for the invite-a-teammate flow
# (internal/zitadelmgmt). Leave blank to run without it.
ZITADEL_SERVICE_ACCOUNT_KEY_PATH=
ZITADEL_ORG_ID=

# Your local listmonk fork's Operator API (see internal/operatorclient
# and docs/plan.md). Token is listmonk's own config.toml's [operator].token.
LISTMONK_OPERATOR_BASE_URL=http://localhost:9000
LISTMONK_OPERATOR_TOKEN=
LISTMONK_ROOT_DOMAIN=listmonk.test

# Optional: creates a dedicated Postmark server for every new instance
# (internal/postmarkclient, internal/provisioning.CreateInstance) and lets
# the org add its own sending domain or sender signature afterward
# (AddSenderDomain/AddSenderSignature), or opt into a subdomain of ours if
# they don't have one (AddPlatformDomain). Leave blank to skip this step --
# instances still provision fine using listmonk's own placeholder SMTP
# examples.
POSTMARK_ACCOUNT_TOKEN=
# Required if POSTMARK_ACCOUNT_TOKEN is set. Base64 AES-256 key encrypting
# postmark_servers.api_token_encrypted at rest -- generate with:
#   openssl rand -base64 32
POSTMARK_TOKEN_ENCRYPTION_KEY=
# Parent domain handed out to an org with no domain of its own -- an
# instance with slug "acme" gets acme.<this>. The DKIM record for each
# such subdomain is ours to publish, not the org's.
POSTMARK_SHARED_DOMAIN_ROOT=mail.listnun.app

# Optional: lets an org point their own domain (e.g. mail.acme.com) at
# their instance instead of only {slug}.{root_domain}
# (internal/provisioning's AddCustomDomain/GetCustomDomain/
# DeleteCustomDomain). Leave blank to skip this feature -- instances stay
# reachable only at {slug}.{root_domain}. See docs/custom-domains.md.
#
# CLOUDFLARE_FALLBACK_ORIGIN alone is enough to turn this on right now:
# our own hostname, proxied through Cloudflare, that every org CNAMEs
# their custom domain at -- the org's own DNS never has to be on
# Cloudflare, a CNAME works the same regardless of registrar.
#
# INTERIM MODE: until Cloudflare's "SSL for SaaS" is enabled on our zone,
# provisioning.Service only verifies the org's CNAME via plain DNS -- no
# TLS certificate is issued yet, so a custom domain isn't served over
# HTTPS. CLOUDFLARE_API_TOKEN/ZONE_ID below are unused until that's wired
# back in -- safe to leave blank for now.
CLOUDFLARE_FALLBACK_ORIGIN=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
